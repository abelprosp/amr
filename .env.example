# Supabase (auth + perfis + acessos)
# Dashboard: https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role (só no servidor; nunca exponha no front)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (ChatGPT) – respostas com contexto dos treinamentos
# Ver: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional: modelo (padrão gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Webhook HM: notificar atualizações (POST) e opcionalmente listar treinamentos (GET)
WEBHOOK_HM_UPDATES=https://webhook.fiqon.app/webhook/a1264b03-c787-451c-a90f-e3046f7170c4/f4cf2009-dfd3-4561-bd33-a6b44e6f87a5
# Opcional: URL para GET da lista de treinamentos HM (se não informado, usa WEBHOOK_HM_UPDATES)
# WEBHOOK_HM_TRAININGS_GET=
